{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build ROS2 Package",
            "type": "shell",
            "command": "colcon",
            "args": ["build", "--packages-select", "test_callback_groups"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "options": {
                "cwd": "/home/root/ws"
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run Action Server",
            "type": "shell",
            "command": "ros2",
            "args": ["run", "test_callback_groups", "do_work_server"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": true,
                "clear": false
            },
            "options": {
                "cwd": "/home/root/ws"
            },
            "dependsOn": "Build ROS2 Package"
        }
    ]
}